# ─────────────────────────────────────────────────────────────────────────────
# Sports AI Predictor — Environment Configuration
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite (default, good for single-server)
DATABASE_URL=sqlite+aiosqlite:///./sports_ai.db
DATABASE_URL_SYNC=sqlite:///./sports_ai.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost/sportsai
# DATABASE_URL_SYNC=postgresql://user:pass@localhost/sportsai

# ── The Odds API ──────────────────────────────────────────────────────────────
# Sign up free at https://the-odds-api.com
# Free tier: 500 requests/month. Standard: $99/month (10k requests).
# Used for: real upcoming odds + completed match scores (result resolution).
ODDS_API_KEY=

# ── API-Football ──────────────────────────────────────────────────────────────
# Sign up at https://www.api-football.com or via RapidAPI
# Free tier: 100 requests/day. Standard: ~$10/month.
# Used for: full season schedules, current fixtures, confirmed results.
API_FOOTBALL_KEY=

# ── Email (optional — required for daily email reports) ───────────────────────
# Gmail: enable 2FA then create an App Password at myaccount.google.com/apppasswords
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your@gmail.com
EMAIL_SMTP_PASS=your-app-password
EMAIL_FROM=Sports AI <your@gmail.com>
EMAIL_RECIPIENT=recipient@example.com

# ── Decision engine thresholds ────────────────────────────────────────────────
PLAY_PROB_THRESHOLD=0.65
PLAY_CONFIDENCE_THRESHOLD=70.0
DAILY_EMAIL_HOUR=8

# ── CORS (add your production domain) ────────────────────────────────────────
# CORS_ORIGINS=["https://yourdomain.com","http://localhost:5173"]
